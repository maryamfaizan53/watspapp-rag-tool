# ── PostgreSQL (Neon or local) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/psx_chatbot

# ── JWT Auth ──────────────────────────────────────────────────────────
JWT_SECRET=9a16237612f775159f3c6a25f02746c6860bea624955c39997e60cc209b09974
JWT_EXPIRE_MINUTES=480

# ── OpenAI (Whisper transcription) ───────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Ollama (local LLM) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Redis (rate limiting) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Embeddings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ── FAISS index storage ──────────────────────────────────────────────
FAISS_INDEX_DIR=./indexes

# ── Encryption key (Fernet) for channel secrets ──────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key

# ── Admin seed user (first run only) ────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password

# ── Frontend URL (for CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Environment ──────────────────────────────────────────────────────
ENVIRONMENT=development
DISABLE_DOCS=false
