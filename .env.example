# ── MongoDB ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/psx_chatbot

# ── JWT Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=480

# ── OpenAI (Whisper transcription) ───────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ollama (local LLM) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Redis (rate limiting) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Embeddings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── FAISS index storage ──────────────────────────────────────────────
FAISS_INDEX_DIR=./indexes

# ── Encryption key (Fernet) for channel secrets ──────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-fernet-key

# ── Admin seed user (first run only) ────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password

# ── Frontend URL (for CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Environment ──────────────────────────────────────────────────────
ENVIRONMENT=development
DISABLE_DOCS=false
