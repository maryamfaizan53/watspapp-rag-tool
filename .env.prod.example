# ── Copy to .env.prod and fill in real values ─────────────────────────────

# ── PostgreSQL (local Docker — no Neon needed) ────────────────────────────
POSTGRES_USER=psx_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=psx_chatbot

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_EXPIRE_MINUTES=1440

# ── LLM (Gemini) ──────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI (Whisper — voice messages only, optional) ─────────────────────
OPENAI_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-small
FAISS_INDEX_DIR=./indexes

# ── Ollama (not used when LLM_PROVIDER=gemini) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Encryption key (Fernet) for channel secrets ───────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ── Admin seed user (created on first startup) ────────────────────────────
SEED_ADMIN_EMAIL=admin@youremail.com
SEED_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── URLs — replace YOUR_ORACLE_IP with your VM's public IP ───────────────
FRONTEND_URL=http://YOUR_ORACLE_IP
VITE_API_URL=http://YOUR_ORACLE_IP

# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production
DISABLE_DOCS=false
